article
  header
    .posttitle
      margin-top: 0
      margin-bottom: 0
      text-transform: none
      font-size: 1.5em
      line-height: 1.25

    .meta
      margin-top: 0
      margin-bottom: 1rem

    .meta *
      color: $color-accent-3
      font-size: .85rem

    .author
      text-transform: uppercase
      letter-spacing: .01em
      font-weight: 700

    .postdate
      display: inline

  .content
    h1
    h2
      margin-left: 2rem

    h1:before
      position: absolute
      left: -2rem
      color: $color-accent-1
      content: "#"
      font-weight: bold
      font-size: 1.5rem

    h2:before
      position: absolute
      top: -4px
      left: -2rem
      color: $color-accent-1
      content: "##"
      font-weight: bold
      font-size: 1.2rem

    img
    video
      display: block
      margin: auto
      max-width: 100%
      height: auto

    /* http://webdesignerwall.com/tutorials/css-elastic-videos */
    .video-container
      position: relative
      overflow: hidden
      padding-top: (9 / 16 * 100)% // 16:9 ratio
      height: 0

      iframe, object, embed
        position: absolute
        top: 0
        left: 0
        margin-top: 0
        width: 100%
        height: 100%

    blockquote
      font-size: .9rem
      margin: 1rem 10px
      padding: .5em 10px
      background: inherit
      color: $color-quote
      quotes: "\201C" "\201D" "\2018" "\2019"
      font-weight: bold

      p
        margin: 0

      &:before
        margin-right: .25em
        color: $color-quote
        content: "\201C"
        vertical-align: -.4em
        font-size: 2em
        line-height: .1em

      footer
        margin: line-height 0
        color: $color-meta
        font-size: 12px

        a
          background-image: linear-gradient(transparent, transparent 5px, $color-meta 5px, $color-meta)
          color: $color-meta

        a:hover
          background-image: linear-gradient(transparent, transparent 4px, lighten($color-meta, 20%) 4px, lighten($color-meta, 20%))
          color: lighten($color-meta, 20%)

        cite
          &:before
            padding: 0 .5em
            content: "—"

    .pullquote
      margin: 0
      width: 45%
      text-align: left

      &.left
        margin-right: 1em
        margin-left: .5em

      &.right
        margin-right: .5em
        margin-left: 1em

    .caption
      position: relative
      display: block
      margin-top: .5em
      color: $color-meta
      text-align: center
      font-size: .9em

.posttitle
  text-transform: none
  font-size: 1.5em
  line-height: 1.25

.article-tag
  .tag-link
    &:before
      content: "#"
    underline(10px, $color-link)

.note
  position: relative
  width: 100%
  background: rgba(0, 0, 0, 0.2)
  padding-left: 2.5rem
  padding-right: 1rem
  margin: 0.5rem 0
  border-radius: 3px
  border-left: 3px solid #eee

.note::before
  font-size: 1.2rem;
  left: 0.5rem;
  position: absolute;
  top: calc(50% - 0.9rem);

.note.default
  border-left: 3px solid #777

  &:before
    content: '\f0a9'
    font-family: 'Font Awesome 6 Free'
    font-weight: 900
    color: #777

.note.primary
  border-left: 3px solid #6f42c1

  &:before
    content: '\f055'
    font-family: 'Font Awesome 6 Free'
    font-weight: 900
    color: #6f42c1

.note.info
  border-left: 3px solid #428bca

  &:before
    content: '\f05a'
    font-family: 'Font Awesome 6 Free'
    font-weight: 900
    color: #428bca

.note.success
  border-left: 3px solid #5cb85c

  &:before
    content: '\f058'
    font-family: 'Font Awesome 6 Free'
    font-weight: 900
    color: #5cb85c

.note.warning
  border-left: 3px solid #f0ad4e

  &:before
    content: '\f06a'
    font-family: 'Font Awesome 6 Free'
    font-weight: 900
    color: #f0ad4e

.note.danger
  border-left: 3px solid #d9534f

  &:before
    content: '\f056'
    font-family: 'Font Awesome 6 Free'
    font-weight: 900
    color: #d9534f

.figure
  text-align: center
  margin: 1.5rem 0

.figure img
  width: 500px
  height: auto
  aspect-ratio: 16 / 9 
  object-fit: cover
  object-position: center center

  @supports not (aspect-ratio: 1/1)
    height 300px

.figure figcaption
  font-size: 0.9rem
  color: #888
  margin-top: 0.5rem

input[type="checkbox"]
  -webkit-appearance: none
  appearance: none
  width: 18px
  height: 18px
  border: 1px solid #444
  border-radius: 3px
  background: #2a2a2a
  position: relative
  outline: none
  vertical-align: middle
  margin-top: -3px

  &:disabled
    cursor: not-allowed
    opacity: 0.7

  &:checked:disabled
    background: #333
    border-color: #555

    &::after
      content: ''
      position: absolute
      display: block
      left: 5px
      top: 1px
      width: 5px
      height: 10px
      border: solid #999
      border-width: 0 2px 2px 0
      transform: rotate(45deg)

ul:has(li input[type="checkbox"])
  list-style: none
  margin: 0
  padding: 0
  padding: 5px 0

li:has(input[type="checkbox"])
  margin: 0
  padding: 0
  padding: 5px 0

table
  th
    white-space: nowrap

@media (min-width: 480px)
  .article-tag,
  .article-category
    display: inline

    &:before
      content: "|"
