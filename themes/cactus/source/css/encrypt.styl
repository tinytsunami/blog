@import "_variables"
@import "_colors/" + $colors
@import "_wave"

.hbe-input-field
    float: none
    height: 2rem
    padding: 2px
    margin-bottom: 0
    font-size: 1rem
    opacity: 1
    caret-shape: block
    text-security: square
    -webkit-text-security: square

    underscoreSawtooth($underline-width, rgba($color-text, 0.2))

    &::placeholder 
        font-size: 1rem
        color: rgba($color-text, 0.2)

    &:focus
        color: $color-border
        underscoreSawtooth($underline-width, $color-border)

.hbe-input-label
    display: none

.hbe-button
    width: 120px
    display: block
    color: $color-border
    border-bottom: none
    padding: 0
    margin-top: 40px
    margin-bottom: 0

    underscoreSawtooth($underline-width, $color-border)

    &:hover
        color: rgba($color-text, 0.2)
        underscoreSawtooth($underline-width, rgba($color-text, 0.2))

.hbe-button:after
    display: none