<% if(page.comments && theme.disqus.enabled){ %>
    <div class="blog-post-comments">
        <div id="disqus_thread">
            <noscript><%= __('comments.no_js') %></noscript>
        </div>
    </div>
<% } %>
<% if(page.comments && theme.utterances.enabled){ %>
    <div class="blog-post-comments">
        <div id="utterances_thread">
            <noscript><%= __('comments.no_js') %></noscript>
        </div>
    </div>
<% } %>
<% if(page.comments && theme.giscus.enabled){ %>
    <div class="blog-post-comments">
        <script src="https://giscus.app/client.js"
                data-repo="<%= theme.giscus.repo_name %>"
                data-repo-id="<%= theme.giscus.repo_id %>"
                data-category="<%= theme.giscus.category_name %>"
                data-category-id="<%= theme.giscus.category_id %>"
                data-mapping="pathname"
                data-strict="0"
                data-reactions-enabled="1"
                data-emit-metadata="0"
                data-input-position="<%= theme.giscus.position %>"
                data-theme="<%= theme.giscus.theme %>"
                data-lang="en"
                data-loading="lazy"
                crossorigin="anonymous"
                async>
        </script>
    </div>
<% } %>
